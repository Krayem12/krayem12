# =============================================
# 🎯 نظام التداول الآلي - الإعدادات الشاملة
# =============================================
# هذا الملف يحتوي على جميع إعدادات نظام التداول الآلي
# يمكنك تعديل أي إعداد حسب احتياجاتك الاستراتيجية
# =============================================

# =============================================
# 🔧 الإعدادات الأساسية للنظام
# =============================================

# وضع التصحيح: تفعيل لعرض رسائل التصحيح، إيقاف في البيئة الإنتاجية
DEBUG=true

# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# منفذ الخادم: يجب أن يكون بين 1 و 65535
PORT=10000

# =============================================
# 📱 إعدادات Telegram للإشعارات
# =============================================

# تفعيل إرسال إشعارات التليجرام: true/false
TELEGRAM_ENABLED=true

# توكن بوت التليجرام (احصل عليه من BotFather)
TELEGRAM_BOT_TOKEN=8058697981:AAH0aOKTGryg5bJoJrQ2RGNkbtE5CeC0DuU

# معرف الدردشة في التليجرام (أرسل رسالة للبوت ثم استخرج المعرف)
TELEGRAM_CHAT_ID=624881400

# =============================================
# 🌐 إعدادات الخادم الخارجي
# =============================================

# تفعيل الإرسال للخادم الخارجي: true/false
EXTERNAL_SERVER_ENABLED=false

# رابط الخادم الخارجي لاستقبال الإشعارات
EXTERNAL_SERVER_URL=https://backend-thrumming-moon-2807.fly.dev/sendMessage

# =============================================
# ⚙️ إعدادات إدارة الصفقات والحدود
# =============================================

# الحد الأقصى للصفقات المفتوحة في نفس الوقت
MAX_OPEN_TRADES=10000

# الحد الأقصى للصفقات لكل رمز تداول
MAX_TRADES_PER_SYMBOL=1001

# =============================================
# 🎯 استراتيجية فتح الصفقات (Trading Strategy)
# =============================================

# نمط التداول: GROUP1, GROUP1_GROUP2, GROUP1_GROUP3, GROUP1_GROUP2_GROUP3
TRADING_MODE=GROUP1_GROUP3

# =============================================
# ⚙️ إعدادات المجموعة الأولى (Group1 - الأساسية)
# =============================================

# عدد الإشارات المطلوبة من المجموعة الأولى لفتح الصفقة
REQUIRED_CONFIRMATIONS_GROUP1=3

# نمط محاذاة الاتجاه: ONLY_TREND أو ALLOW_COUNTER_TREND
GROUP1_TREND_MODE=ONLY_TREND

# =============================================
# ⚙️ إعدادات المجموعة الثانية (Group2 - التأكيدية)
# =============================================

# تفعيل استخدام المجموعة الثانية: true/false
GROUP2_ENABLED=true

# عدد الإشارات المطلوبة من المجموعة الثانية
REQUIRED_CONFIRMATIONS_GROUP2=1

# =============================================
# ⚙️ إعدادات المجموعة الثالثة (Group3 - الداعمة)
# =============================================

# تفعيل استخدام المجموعة الثالثة: true/false
GROUP3_ENABLED=true

# عدد الإشارات المطلوبة من المجموعة الثالثة
REQUIRED_CONFIRMATIONS_GROUP3=1

# =============================================
# 📈 إعدادات استراتيجية الاتجاه
# =============================================

# احترام الاتجاه في الصفقات العادية: true/false
RESPECT_TREND_FOR_REGULAR_TRADES=true

# احترام الاتجاه في صفقات المجموعة الثانية: true/false
RESPECT_TREND_FOR_GROUP2=true

# إعادة تعيين الصفقات عند تغيير الاتجاه: true/false
RESET_TRADES_ON_TREND_CHANGE=true

# =============================================
# ⏰ إعدادات توقيت الإشارات
# =============================================

# وقت انتهاء تأكيد الإشارات (بالثواني)
CONFIRMATION_TIMEOUT=900

# وقت انتهاء التأكيد المزدوج (بالثواني)
DUAL_CONFIRMATION_TIMEOUT=3600

# =============================================
# 🔔 التحكم في إرسال الرسائل
# =============================================

# إرسال رسائل تغيير الاتجاه: true/false
SEND_TREND_MESSAGES=true

# إرسال رسائل الدخول في الصفقات: true/false
SEND_ENTRY_MESSAGES=true

# إرسال رسائل الخروج من الصفقات: true/false
SEND_EXIT_MESSAGES=true

# إرسال رسائل التأكيد: true/false
SEND_CONFIRMATION_MESSAGES=false

# إرسال الرسائل العامة: true/false
SEND_GENERAL_MESSAGES=false

# إرسال الإشارات الصاعدة: true/false
SEND_BULLISH_SIGNALS=true

# إرسال الإشارات الهابطة: true/false
SEND_BEARISH_SIGNALS=true

# =============================================
# 🧹 إعدادات التنظيف التلقائي
# =============================================

# تفعيل التنظيف اليومي التلقائي: true/false
DAILY_CLEANUP_ENABLED=true

# وقت التنظيف اليومي (توقيت السيرفر)
DAILY_CLEANUP_TIME=01:00

# =============================================
# 📚 الكلمات المفتاحية لتصنيف الإشارات
# =============================================

# الكلمات الدالة على الإشارات الصاعدة
BULLISH_KEYWORDS=bullish,buy,long,call,up,upside,rising,recovery,rally,breakout,bullish_confirmation,over

# الكلمات الدالة على الإشارات الهابطة
BEARISH_KEYWORDS=bearish,sell,short,put,down,downside,falling,decline,breakdown,correction,bearish_confirmation,under

# الكلمات الدالة على إشارات الاتجاه
TREND_KEYWORDS=catcher

# الكلمات الدالة على تأكيد الاتجاه
TREND_CONFIRM_KEYWORDS=tracer

# الكلمات الدالة على إشارات الخروج
EXIT_KEYWORDS=exit,close,take profit,stop loss,target,profit taking,cut loss

# الكلمات الدالة على إشارات المجموعة الثالثة
GROUP3_KEYWORDS=moneyflow_above_50,moneyflow_below_50,SPX500

# =============================================
# 📊 قوائم الإشارات الدقيقة
# =============================================

# إشارات تغيير الاتجاه
TREND_SIGNALS=switch_bullish_catcher,switch_bearish_catcher,bullish_catcher,bearish_catcher

# إشارات تأكيد الاتجاه
TREND_CONFIRM_SIGNALS=switch_bullish_tracer,switch_bearish_tracer

# إشارات الدخول الصاعدة (المجموعة الأولى)
ENTRY_SIGNALS_BULLISH=bullish moneyflow_co_50,oversold_bullish_hyperwave_signal,bullish_divergence,bullish_confirmation+,bullish_schoch+

# إشارات الدخول الهابطة (المجموعة الأولى)
ENTRY_SIGNALS_BEARISH=Bearish moneyflow_cu_50,overbought_bearish_hyperwave_signal,bearish_divergence,bearish_confirmation+,bearish_schoch+

# إشارات الدخول الصاعدة (المجموعة الثانية)
ENTRY_SIGNALS_BULLISH1=Discount

# إشارات الدخول الهابطة (المجموعة الثانية)
ENTRY_SIGNALS_BEARISH1=Premium

# إشارات المجموعة الثالثة
ENTRY_SIGNALS_GROUP3=moneyflow_above_50,moneyflow_below_50

# إشارات الخروج
EXIT_SIGNALS=bullish_exit,bearish_exit,take_profit,stop_loss,exit_buy,exit_sell

# الإشارات العامة
GENERAL_SIGNALS=krayem yhia alanizy

