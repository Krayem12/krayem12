# =============================================
# 🎯 نظام التداول الآلي - الإعدادات الشاملة
# =============================================

# =============================================
# 🔧 الإعدادات الأساسية للنظام
# =============================================

# وضع التصحيح: تفعيل لعرض رسائل التصحيح، إيقاف في البيئة الإنتاجية
DEBUG=true

# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# منفذ الخادم: يجب أن يكون بين 1 و 65535
PORT=10000

# =============================================
# 📱 إعدادات Telegram للإشعارات
# =============================================

# تفعيل إرسال إشعارات التليجرام: true/false
TELEGRAM_ENABLED=true

# توكن بوت التليجرام (احصل عليه من BotFather)
TELEGRAM_BOT_TOKEN=8058697981:AAH0aOKTGryg5bJoJrQ2RGNkbtE5CeC0DuU

# معرف الدردشة في التليجرام (أرسل رسالة للبوت ثم استخرج المعرف)
TELEGRAM_CHAT_ID=624881400

# =============================================
# 🌐 إعدادات الخادم الخارجي
# =============================================

# تفعيل الإرسال للخادم الخارجي: true/false
EXTERNAL_SERVER_ENABLED=false

# رابط الخادم الخارجي لاستقبال الإشعارات
EXTERNAL_SERVER_URL=https://backend-thrumming-moon-2807.fly.dev/sendMessage

# =============================================
# ⚙️ إعدادات إدارة الصفقات والحدود
# =============================================

# الحد الأقصى للصفقات المفتوحة في نفس الوقت
MAX_OPEN_TRADES=10

# الحد الأقصى للصفقات لكل رمز تداول
MAX_TRADES_PER_SYMBOL=10

# =============================================
# 🎯 استراتيجية فتح الصفقات (Trading Strategy)
# =============================================

# النمط الأساسي - يفتح صفقات النوع الأساسي
TRADING_MODE=GROUP1_GROUP2_GROUP3

# النمط الأول - يفتح صفقات النوع الأول  
TRADING_MODE1=GROUP1_GROUP3

# النمط الثاني - يفتح صفقات النوع الثاني
TRADING_MODE2=GROUP1_GROUP2_GROUP3

# تفعيل الأنماط الإضافية
TRADING_MODE1_ENABLED=true
TRADING_MODE2_ENABLED=false

# =============================================
# ⚙️ إعدادات المجموعة الأولى (Group1 - الأساسية)
# =============================================

# عدد الإشارات المطلوبة من المجموعة الأولى لفتح الصفقة
REQUIRED_CONFIRMATIONS_GROUP1=1

# نمط محاذاة الاتجاه: ONLY_TREND أو ALLOW_COUNTER_TREND
GROUP1_TREND_MODE=ONLY_TREND

# =============================================
# ⚙️ إعدادات المجموعة الثانية (Group2 - التأكيدية)
# =============================================

# تفعيل استخدام المجموعة الثانية: true/false
GROUP2_ENABLED=true

# عدد الإشارات المطلوبة من المجموعة الثانية
REQUIRED_CONFIRMATIONS_GROUP2=1

# =============================================
# ⚙️ إعدادات المجموعة الثالثة (Group3 - الداعمة)
# =============================================

# تفعيل استخدام المجموعة الثالثة: true/false
GROUP3_ENABLED=true

# عدد الإشارات المطلوبة من المجموعة الثالثة
REQUIRED_CONFIRMATIONS_GROUP3=1

# =============================================
# 📈 إعدادات استراتيجية الاتجاه
# =============================================

# إعادة تعيين الصفقات عند تغيير الاتجاه: true/false
RESET_TRADES_ON_TREND_CHANGE=true

# =============================================
# 🔔 التحكم في إرسال الرسائل
# =============================================

# إرسال رسائل تغيير الاتجاه: true/false
SEND_TREND_MESSAGES=true

# إرسال رسائل الدخول في الصفقات: true/false
SEND_ENTRY_MESSAGES=true

# إرسال رسائل الخروج من الصفقات: true/false
SEND_EXIT_MESSAGES=true

# إرسال رسائل التأكيد: true/false
SEND_CONFIRMATION_MESSAGES=true

# إرسال الرسائل العامة: true/false
SEND_GENERAL_MESSAGES=true

# =============================================
# 🧹 إعدادات التنظيف التلقائي
# =============================================

# تفعيل التنظيف اليومي التلقائي: true/false
DAILY_CLEANUP_ENABLED=true

# وقت التنظيف اليومي (توقيت السيرفر)
DAILY_CLEANUP_TIME=22:00

# =============================================
# ⏰ إعدادات انتهاء صلاحية الإشارات
# =============================================

# وقت انتهاء صلاحية الإشارات بالدقائق (افتراضي 180 دقيقة = 3 ساعات)
SIGNAL_TTL_MINUTES=180

# =============================================
# 📊 قوائم الإشارات الدقيقة
# =============================================

# إشارات تغيير الاتجاه
TREND_SIGNALS=bullish_tracer,bearish_tracer,switch_bullish_trace,switch_bearish_tracer

# إشارات تأكيد الاتجاه
TREND_CONFIRM_SIGNALS=rayian

# إشارات الدخول الصاعدة (المجموعة الأولى)
ENTRY_SIGNALS_BULLISH=oversold_bullish_hyperwave_signal,regular_bullish_hyperwave_signal

# إشارات الدخول الهابطة (المجموعة الأولى)
ENTRY_SIGNALS_BEARISH=overbought_bearish_hyperwave_signal,regular_bearish_hyperwave_signal

# إشارات الدخول الصاعدة (المجموعة الثانية)
ENTRY_SIGNALS_BULLISH1=Discount,bullish_catcher

# إشارات الدخول الهابطة (المجموعة الثانية)
ENTRY_SIGNALS_BEARISH1=Premium,bearish_catcher

# =============================================
# 🟢 إشارات GROUP3 الصاعدة (Bullish)
# =============================================
ENTRY_SIGNALS_GROUP3_BULLISH=bullish_moneyflow_above_50,bullish_moneyflow_co_50

# =============================================
# 🔴 إشارات GROUP3 الهابطة (Bearish)  
# =============================================
ENTRY_SIGNALS_GROUP3_BEARISH=bearish_moneyflow_below_50,bearish_moneyflow_cu_50

# إشارات الخروج
EXIT_SIGNALS=exit_buy,exit_sell

# الإشارات العامة
GENERAL_SIGNALS=krayem yhia alanizy