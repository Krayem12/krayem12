# ==============================================
# 🎯 نظام التداول الآلي - إعدادات البيئة
# ==============================================

# ==============================================
# 🔧 الإعدادات الأساسية للنظام
# ==============================================

# وضع التصحيح: تفعيل/تعطيل وضع التصحيح (true/false)
DEBUG=true

# مستوى التسجيل: تحديد مستوى التفاصيل في السجلات (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=DEBUG

# منفذ الخادم: المنفذ الذي يعمل عليه الخادم (1-65535)
PORT=10000

# ==============================================
# 📱 إعدادات التليجرام
# ==============================================

# تفعيل التليجرام: تفعيل/تعطيل إشعارات التليجرام (true/false)
TELEGRAM_ENABLED=true

# رمز بوت التليجرام: الرمز الخاص ببوت التليجرام
TELEGRAM_BOT_TOKEN=8058697981:AAH0aOKTGryg5bJoJrQ2RGNkbtE5CeC0DuU

# معرف المحادثة: المعرف الخاص بمجموعة/قناة التليجرام
TELEGRAM_CHAT_ID=624881400

# ==============================================
# 🌐 إعدادات الخادم الخارجي
# ==============================================

# تفعيل الخادم الخارجي: إرسال الإشعارات لخادم خارجي (true/false)
EXTERNAL_SERVER_ENABLED=false

# رابط الخادم الخارجي: الرابط المستهدف لإرسال الإشعارات
EXTERNAL_SERVER_URL=https://backend-thrumming-moon-2807.fly.dev/sendMessage

# ==============================================
# 💼 إعدادات إدارة الصفقات
# ==============================================

# الحد الأقصى للصفقات المفتوحة: أقصى عدد للصفقات المفتوحة في نفس الوقت
MAX_OPEN_TRADES=10

# الحد الأقصى للصفقات لكل رمز: أقصى عدد للصفقات المفتوحة لنفس الرمز
MAX_TRADES_PER_SYMBOL=10

# ==============================================
# 🎯 إعدادات استراتيجيات التداول المتعددة
# ==============================================

# الاستراتيجية الرئيسية: المجموعات المستخدمة في النمط الأساسي (GROUP1_GROUP2_etc)
TRADING_MODE=GROUP1_GROUP2_GROUP3_GROUP5

# الاستراتيجية الإضافية 1: المجموعات المستخدمة في النمط الإضافي الأول
TRADING_MODE1=GROUP3_GROUP4

# تفعيل النمط الإضافي 1: تفعيل/تعطيل النمط الإضافي الأول (true/false)
TRADING_MODE1_ENABLED=true

# الاستراتيجية الإضافية 2: المجموعات المستخدمة في النمط الإضافي الثاني
TRADING_MODE2=GROUP4_GROUP5_GROUP2

# تفعيل النمط الإضافي 2: تفعيل/تعطيل النمط الإضافي الثاني (true/false)
TRADING_MODE2_ENABLED=true

# ==============================================
# 📊 إعدادات المجموعات
# ==============================================

# عدد التأكيدات المطلوبة للمجموعة 1: عدد الإشارات المطلوبة من GROUP1 لفتح صفقة
REQUIRED_CONFIRMATIONS_GROUP1=1

# نمط اتجاه المجموعة 1: 
#   ONLY_TREND = يفتح الصفقات فقط في اتجاه الاتجاه الحالي
#   ALLOW_COUNTER_TREND = يفتح الصفقات في أي اتجاه (مخالف أو موافق)
GROUP1_TREND_MODE=ONLY_TREND

# تفعيل المجموعة 2: تفعيل/تعطيل المجموعة الثانية (true/false)
GROUP2_ENABLED=true

# عدد التأكيدات المطلوبة للمجموعة 2: عدد الإشارات المطلوبة من GROUP2 لفتح صفقة
REQUIRED_CONFIRMATIONS_GROUP2=1

# تفعيل المجموعة 3: تفعيل/تعطيل المجموعة الثالثة (true/false)
GROUP3_ENABLED=true

# عدد التأكيدات المطلوبة للمجموعة 3: عدد الإشارات المطلوبة من GROUP3 لفتح صفقة
REQUIRED_CONFIRMATIONS_GROUP3=1

# تفعيل المجموعة 4: تفعيل/تعطيل المجموعة الرابعة (true/false)
GROUP4_ENABLED=true

# عدد التأكيدات المطلوبة للمجموعة 4: عدد الإشارات المطلوبة من GROUP4 لفتح صفقة
REQUIRED_CONFIRMATIONS_GROUP4=1

# تفعيل المجموعة 5: تفعيل/تعطيل المجموعة الخامسة (true/false)
GROUP5_ENABLED=true

# عدد التأكيدات المطلوبة للمجموعة 5: عدد الإشارات المطلوبة من GROUP5 لفتح صفقة
REQUIRED_CONFIRMATIONS_GROUP5=1

# ==============================================
# 📈 إعدادات إدارة الاتجاه
# ==============================================

# إعادة تعيين الصفقات عند تغير الاتجاه: 
#   true = يغلق الصفقات المخالفة عند تغير الاتجاه
#   false = يبقي الصفقات مفتوحة بغض النظر عن تغير الاتجاه
RESET_TRADES_ON_TREND_CHANGE=true

# ==============================================
# 🔔 إعدادات التحكم في الإشعارات
# ==============================================

# إرسال رسائل الاتجاه: إرسال إشعارات عند تغير الاتجاه (true/false)
SEND_TREND_MESSAGES=true

# إرسال رسائل الدخول: إرسال إشعارات عند فتح صفقات جديدة (true/false)
SEND_ENTRY_MESSAGES=true

# إرسال رسائل الخروج: إرسال إشعارات عند إغلاق الصفقات (true/false)
SEND_EXIT_MESSAGES=true


# إرسال الرسائل العامة: إرسال إشعارات عامة عن النظام (true/false)
SEND_GENERAL_MESSAGES=true

# ==============================================
# 🧹 إعدادات التنظيف والصيانة
# ==============================================

# تفعيل التنظيف اليومي: تفعيل/تعطيل التنظيف التلقائي اليومي (true/false)
DAILY_CLEANUP_ENABLED=true

# وقت التنظيف اليومي: الوقت المحدد للتنظيف اليومي (تنسيق 24 ساعة)
DAILY_CLEANUP_TIME=22:00

# مدة صلاحية الإشارات: المدة بالدقائق قبل انتهاء صلاحية الإشارات (1-1440)
SIGNAL_TTL_MINUTES=180

# تخزين الإشارات المخالفة: تخزين/تجاهل الإشارات المخالفة للاتجاه (true/false)
STORE_CONTRARIAN_SIGNALS=true

# ==============================================
# 📡 إشارات التداول - يجب أن تتطابق مع الإشارات الواردة
# ==============================================

# إشارات الاتجاه: الإشارات التي تغير اتجاه السهم
TREND_SIGNALS=bullish_tracer,bearish_tracer,switch_bullish_tracer,switch_bearish_tracer

# إشارات تأكيد الاتجاه: الإشارات التي تؤكد الاتجاه الحالي
TREND_CONFIRM_SIGNALS=rayian

# إشارات الدخول الصاعدة (المجموعة 1): إشارات الدخول للشراء من المجموعة 1
ENTRY_SIGNALS_BULLISH=oversold_bullish_hyperwave_signal,regular_bullish_hyperwave_signal

# إشارات الدخول الهابطة (المجموعة 1): إشارات الدخول للبيع من المجموعة 1
ENTRY_SIGNALS_BEARISH=overbought_bearish_hyperwave_signal,regular_bearish_hyperwave_signal

# إشارات الدخول الصاعدة (المجموعة 2): إشارات الدخول للشراء من المجموعة 2
ENTRY_SIGNALS_BULLISH1=Discount,bullish_catcher

# إشارات الدخول الهابطة (المجموعة 2): إشارات الدخول للبيع من المجموعة 2
ENTRY_SIGNALS_BEARISH1=Premium,bearish_catcher

# إشارات الدخول الصاعدة (المجموعة 3): إشارات الدخول للشراء من المجموعة 3
ENTRY_SIGNALS_GROUP3_BULLISH=bullish_moneyflow_above_50,bullish_moneyflow_co_50

# إشارات الدخول الهابطة (المجموعة 3): إشارات الدخول للبيع من المجموعة 3
ENTRY_SIGNALS_GROUP3_BEARISH=bearish_moneyflow_below_50,bearish_moneyflow_cu_50

# إشارات الدخول الصاعدة (المجموعة 4): إشارات الدخول للشراء من المجموعة 4
ENTRY_SIGNALS_GROUP4_BULLISH=group4_bullish_signal1,group4_bullish_signal2,K1,K2,K3,K4

# إشارات الدخول الهابطة (المجموعة 4): إشارات الدخول للبيع من المجموعة 4
ENTRY_SIGNALS_GROUP4_BEARISH=group4_bearish_signal1,group4_bearish_signal2,KK1,KK2,KK3,KK4

# إشارات الدخول الصاعدة (المجموعة 5): إشارات الدخول للشراء من المجموعة 5
ENTRY_SIGNALS_GROUP5_BULLISH=group5_bullish_signal1,group5_bullish_signal2,R1,R2,R3,R4

# إشارات الدخول الهابطة (المجموعة 5): إشارات الدخول للبيع من المجموعة 5
ENTRY_SIGNALS_GROUP5_BEARISH=group5_bearish_signal1,group5_bearish_signal2,RR1,RR2,RR3,RR4

# إشارات الخروج: الإشارات التي تسبب إغلاق الصفقات
EXIT_SIGNALS=exit_buy,exit_sell

# الإشارات العامة: إشارات أخرى لا تؤثر على التداول
GENERAL_SIGNALS=krayem yhia alanizy

# ==============================================
# 🎯 ملاحظات مهمة:
# ==============================================

# 1. GROUP1_TREND_MODE=ALLOW_COUNTER_TREND يسمح بفتح الصفقات في أي اتجاه
# 2. RESET_TRADES_ON_TREND_CHANGE=false يمنع إغلاق الصفقات عند تغير الاتجاه
# 3. يمكن تعديل أعداد التأكيدات (REQUIRED_CONFIRMATIONS) حسب الحاجة
# 4. الإشارات يجب أن تطابق تماماً ما يرد في الويب هووك
# 5. عند التعديل، يجب إعادة تشغيل النظام لتطبيق التغييرات